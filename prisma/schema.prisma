// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource mydb {
  provider = "postgresql"
}

model VisitLog {
  id        Int      @id @default(autoincrement())
  ip        String
  createdAt DateTime @default(now())
  userAgent String
  path      String
}

model PromptLog {
  id        Int      @id @default(autoincrement())
  prompt    String
  createdAt DateTime @default(now())
}
